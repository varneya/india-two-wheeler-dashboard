# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit real keys.

# Anthropic API key — only needed for the LLM Analysis theme method when
# "Claude" is selected as the backend. The keyword / TF-IDF / Semantic /
# BERTopic methods work without this. The "LLM Analysis" method also works
# offline against any local Ollama model.
ANTHROPIC_API_KEY=
