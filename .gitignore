backend/sales.db
backend/sales.db.bak
backend/*.db
backend/*.db-journal
backend/*.db-shm
backend/*.db-wal

# Server logs
/tmp/uvicorn.log
/tmp/vite.log
/tmp/ollama_*.log

# Plan files + local permission state (Claude Code workflow artefacts)
.claude/plans/
.claude/settings.local.json

# Frontend TS build info
frontend/tsconfig.*.tsbuildinfo
frontend/node_modules/.tmp/
